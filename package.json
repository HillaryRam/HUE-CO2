{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "reverb": "docker exec hueco2-laravel.test-1 php artisan reverb:start",
        "start": "wsl docker compose up -d && docker exec -it hueco2-laravel.test-1 npm run dev",
        "build:docker": "docker exec hueco2-laravel.test-1 bash -c \"npm run build\"",
        "stop": "wsl docker compose down"
    },
    "devDependencies": {
        "@headlessui/react": "^2.0.0",
        "@inertiajs/react": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.2.1",
        "@vitejs/plugin-react": "^5.1.4",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.1",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.60.0",
        "laravel-echo": "^2.3.0",
        "lucide-react": "^0.577.0",
        "motion": "^12.38.0",
        "pusher-js": "^8.4.0"
